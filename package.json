{
  "name": "react-ascii-rickroll",
  "version": "0.0.1",
  "description": "React component to show ASCII Rickroll animation",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:demo": "vite build",
    "preview:demo": "npx serve demo/dist",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goliney/react-ascii-rickroll.git"
  },
  "keywords": [
    "react",
    "rickroll",
    "ascii"
  ],
  "author": "Serhii Holinei",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/goliney/react-ascii-rickroll/issues"
  },
  "homepage": "https://github.com/goliney/react-ascii-rickroll#readme",
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "prettier": "^3.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  }
}
